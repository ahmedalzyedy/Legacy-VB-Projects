   End
   Begin VB.Menu ملف 
      Caption         =   "&ملف"
      Begin VB.Menu add 
         Caption         =   "&اضافة الئ القائمة"
      End
      Begin VB.Menu addtext 
         Caption         =   "&اضافة الئ مربع النص"
      End
