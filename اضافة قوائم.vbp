Attribute VB_Name = "Form1"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Private Sub add_Click()
Dim inputdate As String
inputdate = InputBox("ادخل بيانات القائمة جديدة:")
If inputdate <> "" Then
Me.List1.AddItem inputdate
End If
End Sub

Private Sub addtext_Click()
Dim inputtext As String
inputtext = InputBox("ادخل النص المراد اضافته")
Me.Text1.Text = inputtext
End Sub

Private Sub deleteall_Click()
Me.List1.Clear
Me.Text1.Text = ""

End Sub

Private Sub exit_Click()
If MsgBox("هل تريد الخروج؟", vbYesNo + vbQuestion) = vbYes Then
End
End If
End Sub
